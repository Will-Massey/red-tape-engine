{
  "name": "red-tape-engine",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/api",
    "apps/dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev -w @rte/api",
    "dev:dashboard": "npm run dev -w @rte/dashboard",
    "start": "npm run start -w @rte/api",
    "postinstall": "echo 'Red Tape Engine ready'",
    "db:generate": "npm run db:generate -w @rte/core",
    "db:migrate": "npm run db:migrate -w @rte/core",
    "db:seed": "npm run db:seed -w @rte/core",
    "smoke:tradetap": "npm run smoke -w @rte/tradetap",
    "test:receipt-vision": "npm run test:receipt-vision -w @rte/core",
    "test:agilepilot-policy": "tsx packages/agilepilot/scripts/policy.test.mts",
    "smoke:prod-agilepilot": "node scripts/smoke-prod-agilepilot.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify": "npm run typecheck && npm run test:receipt-vision && npm run test:agilepilot-policy && npm run build && npm run smoke:tradetap"
  },
  "engines": {
    "node": ">=20"
  }
}