{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // @rte/tradetap ships its PDF report as .tsx source, which this app compiles directly.
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*"]
}