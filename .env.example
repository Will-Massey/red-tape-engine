# Database
DATABASE_URL=postgresql://rte:rte@localhost:5433/red_tape_engine

# xAI / Grok
XAI_API_KEY=xai-your-key-here
XAI_MODEL=grok-3-mini

# Twilio (TradeTap)
# Signature validation is enforced whenever TWILIO_AUTH_TOKEN is set and DEMO_MODE is not true.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+44...
# Only needed if the public URL Twilio calls differs from the forwarded headers.
TWILIO_WEBHOOK_BASE_URL=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TRADETAP=price_...
STRIPE_PRICE_COMPLYBOT=price_...
STRIPE_PRICE_PLANNING=price_...
STRIPE_PRICE_AGILE=price_...
STRIPE_PRICE_HOUSE=price_...

# Cal.com (TradeTap booking)
CALCOM_BOOKING_URL=https://cal.com/your-link
# Cal.com webhook secret — when set, x-cal-signature-256 is verified.
CALCOM_WEBHOOK_SECRET=

# Resend (email digests)
# Digest recipients live in tenants.config.digestEmail, not an env var.
RESEND_API_KEY=
RESEND_FROM=PlanningPulse <onboarding@resend.dev>
PLANNINGPULSE_DIGEST_EMAIL=alerts@northbuild.example

# Companies House (HouseSignal)
# Without a key HouseSignal serves demo signals. SIC filtering per tenant comes
# from tenants.config.sicCodes.
COMPANIES_HOUSE_API_KEY=

# Octopus Energy (AgilePilot)
OCTOPUS_API_KEY=

# AgilePilot savings model — flat rate to compare against, and the daily
# shiftable load (EV top-up / appliance cycle) savings are estimated over.
AGILEPILOT_BASELINE_PENCE=24.5
AGILEPILOT_SHIFTABLE_KWH=3.5

# PlanningPulse daily poller (in-process cron; 6am Europe/London by default).
# Set PLANNINGPULSE_POLL_ENABLED=false to disable, e.g. when an external
# scheduler calls POST /api/planningpulse/poll instead.
PLANNINGPULSE_POLL_ENABLED=true
PLANNINGPULSE_POLL_CRON=0 6 * * *
PLANNINGPULSE_POLL_TZ=Europe/London

# App
API_PORT=3847
DASHBOARD_PORT=3848
APP_URL=http://localhost:3847
DEMO_MODE=true